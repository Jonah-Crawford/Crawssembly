sav 98 r01
io text char r01
sav 101 r01
io text char r01
sav 114 r01
io text char r01
io text newline rff

sav 0 r06				; reset second number

1					; first number loop
  sav 0 r02				; reset keycode
  io keyboard poll r02			; get last key
  cal add 5 r02				; test for enter
  ifg 2					; continues if code > -5

    cal add -48 r02			; test for code < numbers
    jml 1				; don't continue if not number
    cal add -57 r02			; test for code > numbers
    jmg 1				; don't continue

    io text char r02			; show digit

    cal add -48 r02			; normalise key code
    sav r01 r03				; save new units digit
    cal add r06 r06			; 2N
    cal add r01 r01			; 4N
    cal add r01 r01			; 8N
    cal add r01 r06			; 9N
    cal add r01 r06			; 10N
    cal add r03 r01			; 10N + new key code = new N
    sav r01 r06				; update new N

    jmp 1				; continue loop

  rmv 2					; ends code < -5 branch
  ifl 2					; continues if code < -5

    cal add -48 r02			; test for code < numbers
    jml 1				; don't continue if not number
    cal add -57 r02			; test for code > numbers
    jmg 1				; don't continue

    io text char r02			; show digit

    cal add -48 r02			; normalise key code
    sav r01 r03				; save new units digit
    cal add r06 r06			; 2N
    cal add r01 r01			; 4N
    cal add r01 r01			; 8N
    cal add r01 r06			; 9N
    cal add r01 r06			; 10N
    cal add r03 r01			; 10N + new key code = new N
    sav r01 r06				; update new N

    jmp 1				; continue loop

  rmv 2					; ends code < -5 branch
rmv 1					; removes loop label

sav r07 r01				; ready calculation mode
ifg 1					; if mode > 0 (subtract)
  cal not r06 rff			; 1st step of negation
  cal add 1 r01				; 2nd step of negation
rmv 1
ifz 1					; if mode = 0 (addition)
  sav r06 r01				; ready second number into register 1
rmv 1

cal add r01 r05				; solve calculation

io text newline rff			; drop down the text cursor
io text newline rff			; drop down the text cursor
io text int r01				; show calculation result
