sav 116 r01
io text char r01
sav 63 r01
io text char r01
io text newline rff

1					; operation loop
  io keyboard poll r02
  cal add -97 r02			; check for code = 97 for 'a'

  ifz 2					; if code = 97 ('a')
    sav 0 r07				; sat operation mode to 0
  rmv 2					; end code = 97 branch

  cal add -115 r02			; check for code = 115 for 's'

  ifz 2					; if code = 115 ('s')
    sav 1 r07				; set operation mode to 1
  rmv 2					; end code = 115 branch 

  ifg 2					; if code > 115 check
    jmp 1				; continue loop
  rmv 2					; end code > 115 branch

  ifl 2					; if code < 115
    cal add -97 r02			; recheck for code = 97
    ifg 3				; 97 < code < 115 check
      jmp 1				; continue loop
    rmv 3				; end 97 < code < 115 check
    ifl 3				; code < 97 check
      jmp 1				; continue loop
    rmv 3				; end code < 97 check
  rmv 2					; end code < 115 check

rmv 1					; end operation loop

io text char r02

io text newline rff			; "\nEnter another number\n"
