; CSL: math/abs.craw
; Inputs: r02
; Outputs: r02
; Scope: r01-r02 | 60000

rmv 60000				; free label

sav r02 r01				; ready input for negative check

ifl 60000				; input is negative
  cal not r02 rff			; negation 1st step
  cal add 1 r01				; negation 2nd step
rmv 60000				; end input is negative check

sav r01 r02				; save result to output register
